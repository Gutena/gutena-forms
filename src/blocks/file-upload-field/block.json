{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutena/file-upload-field",
	"version": "1.0.0",
	"title": "File Upload",
	"parent": [ "gutena/forms" ],
	"category": "gutena-pro",
	"icon": "upload",
	"description": "Allow users to upload files, documents, or images through the form.",
	"keywords": [ "file", "upload", "gutena forms" ],
	"attributes": {
		"nameAttr": { "type": "string", "default": "" },
		"fieldName": { "type": "string", "default": "Upload file" },
		"fieldType": { "type": "string", "default": "file" },
		"isRequired": { "type": "boolean", "default": false },
		"accept": { "type": "string", "default": "" },
		"allowMultiple": { "type": "boolean", "default": false },
		"description": { "type": "string", "default": "" },
		"errorRequiredMsg": { "type": "string", "default": "Field is required" },
		"errorInvalidInputMsg": { "type": "string", "default": "Input is not valid" }
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"spacing": { "margin": true, "padding": true }
	},
	"textdomain": "gutena-forms-pro",
	"editorScript": "file:./index.js"
}
