{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutena/rating-field",
	"version": "1.0.0",
	"title": "Rating",
	"parent": [ "gutena/forms" ],
	"category": "gutena-pro",
	"icon": "star-filled",
	"description": "Gather user feedback using a star-based rating field.",
	"keywords": [ "rating", "stars", "gutena forms" ],
	"attributes": {
		"nameAttr": { "type": "string", "default": "" },
		"fieldName": { "type": "string", "default": "Rating" },
		"fieldType": { "type": "string", "default": "radio" },
		"isRequired": { "type": "boolean", "default": false },
		"selectOptions": {
			"type": "array",
			"default": [ "1", "2", "3", "4", "5" ]
		},
		"optionsColumns": { "type": "number", "default": 1 },
		"optionsInline": { "type": "boolean", "default": true },
		"autocomplete": { "type": "boolean", "default": false },
		"description": { "type": "string", "default": "" },
		"errorRequiredMsg": { "type": "string", "default": "Field is required" },
		"errorInvalidInputMsg": { "type": "string", "default": "Input is not valid" }
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"spacing": { "margin": true, "padding": true }
	},
	"textdomain": "gutena-forms-pro",
	"editorScript": "file:./index.js"
}
