{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutena/email-field",
	"version": "1.0.0",
	"title": "Email Field",
	"parent": [ "gutena/forms" ],
	"category": "gutena",
	"icon": "email",
	"description": "Standalone email input field for Gutena Forms.",
	"keywords": [ "email", "input", "gutena forms" ],
	"attributes": {
		"nameAttr": {
			"type": "string",
			"default": ""
		},
		"fieldName": {
			"type": "string",
			"default": "Email"
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"isRequired": {
			"type": "boolean",
			"default": false
		},
		"defaultValue": {
			"type": "string",
			"default": ""
		},
		"maxlength": {
			"type": "number",
			"default": 0
		},
		"autocomplete": {
			"type": "boolean",
			"default": false
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"errorRequiredMsg": {
			"type": "string",
			"default": "Field is required"
		},
		"errorInvalidInputMsg": {
			"type": "string",
			"default": "Input is not valid"
		},
		"fieldType": {
			"type": "string",
			"default": "email"
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "gutena-forms",
	"editorScript": "file:./index.js"
}
