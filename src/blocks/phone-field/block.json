{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutena/phone-field",
	"version": "1.0.0",
	"title": "Phone Field",
	"parent": [ "gutena/forms" ],
	"category": "gutena-pro",
	"icon": "phone",
	"description": "Capture phone numbers with proper formatting and validation.",
	"keywords": [ "phone", "tel", "gutena forms" ],
	"attributes": {
		"nameAttr": { "type": "string", "default": "" },
		"fieldName": { "type": "string", "default": "Phone" },
		"fieldType": { "type": "string", "default": "phone" },
		"placeholder": { "type": "string", "default": "" },
		"isRequired": { "type": "boolean", "default": false },
		"defaultValue": { "type": "string", "default": "" },
		"maxlength": { "type": "number", "default": 0 },
		"autocomplete": { "type": "boolean", "default": false },
		"description": { "type": "string", "default": "" },
		"errorRequiredMsg": { "type": "string", "default": "Field is required" },
		"errorInvalidInputMsg": { "type": "string", "default": "Input is not valid" }
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"spacing": { "margin": true, "padding": true }
	},
	"textdomain": "gutena-forms-pro",
	"editorScript": "file:./index.js"
}
