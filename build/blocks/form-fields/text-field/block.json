{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutena/text-field",
  "version": "1.0.0",
  "title": "Text",
  "parent": [
    "gutena/forms"
  ],
  "category": "gutena",
  "icon": "text",
  "description": "Collect short text inputs such as names, titles, or single-line responses.",
  "attributes": {
    "nameAttr": {
      "type": "string",
      "default": "f_0"
    },
    "fieldLabel": {
      "type": "string",
      "default": "Label"
    },
    "fieldLabelContent": {
      "type": "string",
      "default": ""
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "defaultValue": {
      "type": "string",
      "default": ""
    },
    "maxlength": {
      "type": "number",
      "default": ""
    },
    "autocomplete": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "errorRequiredMsg": {
      "type": "string",
      "default": "Field is required"
    },
    "errorInvalidInputMsg": {
      "type": "string",
      "default": "Input is not valid"
    }
  },
  "supports": {
    "__experimentalSettings": true,
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "__experimentalLayout": true
  },
  "textdomain": "gutena-forms",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}