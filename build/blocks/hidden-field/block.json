{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutena/hidden-field",
  "version": "1.0.0",
  "title": "Hidden Field",
  "parent": [
    "gutena/forms"
  ],
  "category": "gutena-pro",
  "icon": "hidden",
  "description": "Store additional data invisibly without user interaction.",
  "keywords": [
    "hidden",
    "gutena forms"
  ],
  "attributes": {
    "nameAttr": {
      "type": "string",
      "default": ""
    },
    "fieldName": {
      "type": "string",
      "default": "Hidden value"
    },
    "fieldType": {
      "type": "string",
      "default": "hidden"
    },
    "defaultValue": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "textdomain": "gutena-forms-pro",
  "editorScript": "file:./index.js"
}