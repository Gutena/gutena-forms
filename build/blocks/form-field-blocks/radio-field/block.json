{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutena/radio-field",
  "version": "1.0.0",
  "title": "Radio Field",
  "parent": [
    "gutena/forms"
  ],
  "category": "gutena",
  "icon": "forms",
  "description": "Standalone radio button group for Gutena Forms.",
  "keywords": [
    "radio",
    "choice",
    "gutena forms"
  ],
  "attributes": {
    "nameAttr": {
      "type": "string",
      "default": ""
    },
    "fieldName": {
      "type": "string",
      "default": "Choose one"
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "selectOptions": {
      "type": "array",
      "default": [
        "Option A",
        "Option B",
        "Option C"
      ]
    },
    "optionsColumns": {
      "type": "number",
      "default": 1
    },
    "optionsInline": {
      "type": "boolean",
      "default": false
    },
    "autocomplete": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "errorRequiredMsg": {
      "type": "string",
      "default": "Field is required"
    },
    "errorInvalidInputMsg": {
      "type": "string",
      "default": "Input is not valid"
    },
    "fieldType": {
      "type": "string",
      "default": "radio"
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "textdomain": "gutena-forms",
  "editorScript": "file:./index.js"
}