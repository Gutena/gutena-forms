{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutena/password-field",
  "version": "1.0.0",
  "title": "Password Field",
  "parent": [
    "gutena/forms"
  ],
  "category": "gutena-pro",
  "icon": "lock",
  "description": "Securely collect sensitive information with masked input.",
  "keywords": [
    "password",
    "gutena forms"
  ],
  "attributes": {
    "nameAttr": {
      "type": "string",
      "default": ""
    },
    "fieldName": {
      "type": "string",
      "default": "Password"
    },
    "fieldType": {
      "type": "string",
      "default": "password"
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "defaultValue": {
      "type": "string",
      "default": ""
    },
    "maxlength": {
      "type": "number",
      "default": 0
    },
    "autocomplete": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "errorRequiredMsg": {
      "type": "string",
      "default": "Field is required"
    },
    "errorInvalidInputMsg": {
      "type": "string",
      "default": "Input is not valid"
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "textdomain": "gutena-forms-pro",
  "editorScript": "file:./index.js"
}